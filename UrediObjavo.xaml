<Window x:Class="SocialApp.UrediObjavo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SocialApp"
        mc:Ignorable="d"
        Title="UrediObjavo" MinHeight="550"  MinWidth="350" MaxWidth="400">

        <StackPanel Margin="20">
        <TextBlock Text="Avtor:"/>
        <TextBox Text="{Binding IzbranaObjava.Avtor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
         Width="300" Margin="0,4,0,8"/>

        <TextBlock Text="Datum:"/>
        <TextBox Text="{Binding IzbranaObjava.Datum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
         Width="300" Margin="0,4,0,8"/>
        <TextBlock Text="Vsebina:"/>
        <TextBox Text="{Binding IzbranaObjava.Vsebina, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Width="300" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4,0,8"/>

        <TextBlock Text="Kategorija:"/>
        <TextBox Text="{Binding IzbranaObjava.Kategorija, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Width="300"  Margin="0,4,0,8"/>

        <TextBlock Text="Slika:"/>
        <Image x:Name="ImgSlika" Width="100" Height="100" Stretch="UniformToFill"
               Source="{Binding IzbranaObjava.Slika}"
               Margin="0,4,0,4" Cursor="Hand" MouseLeftButtonUp="ImgSlika_Click"/>
        <TextBlock Text="(klikni za izbiro slike)" FontSize="11" Margin="0,0,0,8" TextAlignment="Center"/>

        <Button Content="Zapri" Width="80" HorizontalAlignment="Right" Click="BtnZapri_Click"/>

    </StackPanel>
    
</Window>

<Window x:Class="SocialApp.DodajObjavo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SocialApp"
        mc:Ignorable="d"
        Title="DodajObjavo" Height="450" MinWidth="350">
    <StackPanel Margin="20">
        <TextBlock Text="Vsebina" />
        <TextBox x:Name="TxtVsebina" Height="100" Margin="0,5,0,15" TextWrapping="Wrap" AcceptsReturn="True" />

        <TextBlock Text="Kategorija" />
        <TextBox x:Name="TxtKategorija"  Margin="0,4,0,8"/>

        <TextBlock Text="Slika:"/>
        <Image x:Name="ImgSlika" Width="100" Height="100" Stretch="UniformToFill"
               Margin="0,4,0,4" Cursor="Hand" MouseLeftButtonUp="ImgSlika_Click"
               Source="/Slike/profile.jpg"/>
        <TextBlock Text="(klikni za izbiro slike)"  Margin="0,0,0,8" TextAlignment="Center"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Dodaj" Width="80" Margin="0,0,8,0" IsDefault="True" Click="BtnDodaj_Click"/>
            <Button Content="Prekliči" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>

<Window x:Class="SocialApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SocialApp"
        mc:Ignorable="d"
        Title="MainWindow" MinWidth="550" MinHeight="450" Width="800" Height="600">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Menu Grid.Row="0" Background="#1877F2" Padding="5">
            <MenuItem Header="Datoteka" Foreground="White" Background="#1877F2" >
                <MenuItem Header="Izhod" Foreground="White" Click="MenuIzhodClick" />
            </MenuItem>
            <MenuItem Header="Objave" Foreground="White" Background="#1877F2"  />
            <MenuItem Header="Dodaj staticno" Foreground="White" Click="MenuDodajObjavoStaticnoClick" />
            <MenuItem Header="Uredi statcno" Foreground="White" Click="MenuUrediObjavoStaticnoClick" />
            <MenuItem Header="Dodaj" Foreground="White" Click="MenuDodajObjavoClick" />
            <MenuItem Header="Uredi" Foreground="White" Click="MenuUrediObjavoClick" />
            <MenuItem Header="Odstrani" Foreground="White" Click="MenuOdstraniObjavoClick" />
        </Menu>


        <Border Grid.Row="1" Background="White" BorderBrush="Gray" Padding="2">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="70" Height="70" CornerRadius="35"  BorderBrush="#1877F2" BorderThickness="2">
                    <Border.Clip>
                        <EllipseGeometry Center="35,35" RadiusX="35" RadiusY="35"/>
                    </Border.Clip>
                    <Image x:Name="ProfilnaSlika" Source="Slike/profile.jpg" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBox x:Name="TXTimeHeader" Text="Tiki Eld" FontSize="16" FontWeight="Bold" IsReadOnly="True" />
                    <TextBox Text="@TikiEld" FontSize="12" Foreground="Gray"  />
                </StackPanel>


                <Border Margin="40,0,0,0" VerticalAlignment="Center">
                    <UniformGrid Rows="1" Columns="3" Width="220">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBox x:Name="TxtStObjav" Text="0" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBox Text="Objave" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBox x:Name="TxtStSledilcev" Text="0" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBox Text="Sledilci" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBox x:Name="TxtStSledi" Text="0" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBox Text="Sledi" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>
            </StackPanel>
        </Border>


        <TabControl Grid.Row="2" Background="#F0F2F5" BorderThickness="0">

            <TabItem Header="Zid">
                <!-- sem pride koraku 5 -->
                <DockPanel Margin=" 20" LastChildFill="True">


                    <Border DockPanel.Dock="Right" Width="200" Background="White" CornerRadius="8" Padding="10" Margin="10" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Nova Objava " FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtNovaObjava"  Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>
                            <Button x:Name ="BtnObjavi" Height="36" Width="32" Margin="0,8,0,0" Click="BtnObjavi_Click">
                                <Image Source="/Slike/paper-plane-top_9821630.png" Width="16" Height="16" />
                            </Button>        
                        </StackPanel>
                    </Border>


                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="ListViewObjave" Grid.Row="0" MouseDoubleClick="ListViewObjave_MouseDoubleClik">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="8" BorderBrush="#CED0D4" BorderThickness="1" Padding="14" Margin="2,4" MinWidth="300">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Avtor}" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Vsebina}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="{Binding Datum}" FontSize="14"/>
                                                <TextBlock Text="{Binding Likes, StringFormat='tu not priejo pol lajki'}" FontSize="14"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button x:Name="BtnVseckaj" Grid.Row="1" Width="36" Height="32" Margin="0,8,0,0" Click="BtnVseckaj_Click">
                            
                                <Image Source="/Slike/heart_3916767.png" Width="16" Height="16" />
                                
                            
                        </Button>


                    </Grid>

                </DockPanel>
            </TabItem>

            <TabItem Header="  O meni" Margin="2,-2,-2,0">
                <!-- sem pride koraku 6 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="White" CornerRadius="8" Margin="20" Padding="25" MaxWidth="500" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <StackPanel>

                            <TextBox Text="Moj profil" FontSize="18"/>

                            <Border Width="80" Height="80" CornerRadius="40" HorizontalAlignment="Left">
                                <Border.Clip>
                                    <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                </Border.Clip>
                                <Image Source="/Slike/profile.jpg" Stretch="UniformToFill"/>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ime:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtIme" Margin="0,3" Text="TIki" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Priimek:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtPriimek" Margin="0,3" Text="Eldarov"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mail:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtMail" Margin="0,3" Text="tiki@gamil.com"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="O meni:" VerticalAlignment="Top"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtOMeni" Margin="0,3" TextWrapping="Wrap" AcceptsReturn="True" Height="60" Text="Sem Tiki Eld"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                                <Button x:Name="BtnShrani"  Height="32" Width="36" Click="BtnShrani_Click" Margin="2">
                                    <Image Source="/Slike/paper-plane-top_9821630.png" Width="16" Height="16" />
                                    
                                </Button>
                                <Button x:Name="BtnSpremeniSliko"  Height="32" Width="36" Click="BtnSpremeniSliko_Click" Margin="2">
                                    <Image Source="/Slike/replace_9291879.png" Width="16" Height="16" />

                                </Button>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>

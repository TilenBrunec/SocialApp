<Window x:Class="SocialApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SocialApp"
        mc:Ignorable="d"
        Title="MainWindow" MinWidth="550" MinHeight="450" Width="800" Height="600">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Datoteka">
                <MenuItem Header="Izhod" Click="MenuIzhodClick"/>
            </MenuItem>
            <MenuItem Header="Objave">
                <MenuItem Header="Dodaj statično" Command="{Binding DodajCommand}"/>
                <MenuItem Header="Uredi statično" Command="{Binding UrediCommand}"/>
                <MenuItem Header="Dodaj"  Command="{Binding OdpriDodajCommand}"/>
                <MenuItem Header="Uredi" Command="{Binding OdpriUrediCommand}"/>
                <MenuItem Header="Odstrani" Command="{Binding OdstraniCommand}"/>
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Style="{StaticResource HeaderBorderStyle}">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource ProfileImageBorderStyle}">
                    <Border.Clip>
                        <EllipseGeometry Center="35,35" RadiusX="35" RadiusY="35"/>
                    </Border.Clip>
                    <Image x:Name="ProfilnaSlika" Source="Slike/profile.jpg" Stretch="UniformToFill"/>
                </Border>

                <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBox x:Name="TXTimeHeader" Text="Tiki Eld" Style="{StaticResource BoldTextBoxStyle}"/>
                    <TextBox Text="@TikiEld" Style="{StaticResource ReadOnlyStyle}" Foreground="{StaticResource grayBrush}"/>
                </StackPanel>

                <StackPanel Margin="40,0,0,0" VerticalAlignment="Center">
                    <UniformGrid Rows="1" Columns="3" Width="220">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBox x:Name="TxtStObjav" Text="0" Style="{StaticResource ReadOnlyStyle}"/>
                            <TextBox Text="Objave" Style="{StaticResource ReadOnlyStyle}" Foreground="{StaticResource grayBrush}"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBox x:Name="TxtStSledilcev" Text="0" Style="{StaticResource ReadOnlyStyle}"/>
                            <TextBox Text="Sledilci" Style="{StaticResource ReadOnlyStyle}" Foreground="{StaticResource grayBrush}"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBox x:Name="TxtStSledi" Text="0" Style="{StaticResource ReadOnlyStyle}"/>
                            <TextBox Text="Sledi" Style="{StaticResource ReadOnlyStyle}" Foreground="{StaticResource grayBrush}"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="2" Style="{StaticResource TabControlStyle}">

            <TabItem Header="Zid" Style="{StaticResource TabItemStyle}">
                <DockPanel Margin="20" LastChildFill="True">

                    <Border DockPanel.Dock="Right" Style="{StaticResource NewPostBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Nova objava" FontWeight="Bold" Margin="0,0,0,8"/>
                            
                            <Button x:Name="BtnObjavi" Style="{StaticResource ButtonStyle}" Command="{Binding OdpriDodajCommand}">
                                <Image Source="Slike/paper-plane-top_9821630.png" Width="16" Height="16"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="ListViewObjave" Grid.Row="0"
                            Style="{StaticResource ListViewStyle}"
                            ItemContainerStyle="{StaticResource ListViewItemStyle}"
                            ItemsSource="{Binding Objave}"
                            SelectedItem="{Binding IzbranaObjava, Mode=TwoWay}"
                            MouseDoubleClick="ListViewObjave_MouseDoubleClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorderStyle}" MinWidth="300">
                                        <StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Slika}" Width="40" Height="40" Stretch="UniformToFill" Margin="0,0,8,0"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock x:Name="TxtAvtor" Text="{Binding Avtor}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Datum}" Foreground="{StaticResource grayBrush}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Vsebina}" TextWrapping="Wrap" Margin="0,6,0,4"/>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Kategorija}" Foreground="{StaticResource grayBrush}" Margin="0,0,12,0"/>
                                                <TextBlock x:Name="TxtLikes" Text="{Binding Likes, StringFormat='❤️ {0}'}"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding BrezVseckov}" Value="True">
                                            <Setter TargetName="TxtLikes" Property="Foreground" Value="Gray"/>
                                            <Setter TargetName="TxtAvtor" Property="Foreground" Value="Gray"/>
                                            <Setter TargetName="TxtLikes" Property="Text" Value="⚪ Brez všečkov"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>

                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button x:Name="BtnVseckaj" Grid.Row="1" Style="{StaticResource ButtonStyle}" Command="{Binding VseckajCommand}">
                            <Image Source="Slike/heart_3916767.png" Width="16" Height="16"/>
                        </Button>
                    </Grid>

                </DockPanel>
            </TabItem>

            <TabItem Header="O meni" Style="{StaticResource TabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="20" Padding="25" MaxWidth="500" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBox Text="Moj profil" FontSize="18" Style="{StaticResource ReadOnlyStyle}"/>

                            <Border Width="80" Height="80" CornerRadius="40" HorizontalAlignment="Left">
                                <Border.Clip>
                                    <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                                </Border.Clip>
                                <Image Source="Slike/profile.jpg" Stretch="UniformToFill"/>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ime:"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtIme"     Text="Tiki"          Style="{StaticResource InputStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Priimek:"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtPriimek" Text="Eldarov"       Style="{StaticResource InputStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mail:"/>
                                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtMail"    Text="tiki@gmail.com" Style="{StaticResource InputStyle}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="O meni:"/>
                                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TxtOMeni"   Text="Sem Tiki Eld"
                                           TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                                           Style="{StaticResource InputStyle}"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Button x:Name="BtnShrani" Style="{StaticResource ButtonStyle}">
                                    <Image Source="Slike/paper-plane-top_9821630.png" Width="16" Height="16"/>
                                </Button>
                                <Button x:Name="BtnSpremeniSliko" Style="{StaticResource ButtonStyle}">
                                    <Image Source="Slike/replace_9291879.png" Width="16" Height="16"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
